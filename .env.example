# Копирай като .env.local и попълни стойностите.
# За Vercel: Settings → Environment Variables.

# URL на сайта (опционално; по подразбиране www.masajipodomovete.com)
# NEXT_PUBLIC_APP_URL=https://www.masajipodomovete.com

# Google Analytics 4 – Measurement ID (вида G-XXXXXXXXXX)
# Вземи от: analytics.google.com → Admin → Data Streams → избери поток → Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=
